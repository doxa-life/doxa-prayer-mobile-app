# Copy to android/fastlane/.env and fill in real values. The real .env is gitignored.
# fastlane loads this automatically when run from the android/ directory.

# Path to the Google Play service account JSON (Play Console -> Setup -> API access).
# The service account must have release permission on BOTH the production and
# staging apps. Use one JSON with access to both, or point this at whichever you use.
PLAY_SERVICE_ACCOUNT_JSON=/home/youruser/play-service-account.json

# Per-target campaigns-server version gate (PUT /api/admin/app-version/config).
# Each token needs the `content.edit` permission.
STAGING_SERVER_URL=https://campaigns-server-k4ax-production.up.railway.app
STAGING_ADMIN_TOKEN=replace_me

PRODUCTION_SERVER_URL=https://pray.doxa.life
PRODUCTION_ADMIN_TOKEN=replace_me
