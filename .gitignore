# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Local secrets (loaded by flutter_dotenv at startup; kept out of source control)
.env
!.env.example

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Fastlane (Android release automation)
/android/fastlane/.env
/android/fastlane/report.xml
/android/fastlane/README.md
/android/vendor/bundle
**/play-service-account*.json

# Store screenshots are generated by tool/screenshots/ (captured against staging,
# framed with ImageMagick). Kept out of git — regenerate, don't commit. The
# `screenshots`/`upload_screenshots` lanes stage them into these image dirs.
/android/fastlane/metadata/*/android/*/images/
/ios/fastlane/screenshots/

# Fastlane (iOS release automation)
/ios/fastlane/.env
/ios/fastlane/report.xml
/ios/fastlane/README.md
/ios/vendor/bundle
**/AuthKey_*.p8
