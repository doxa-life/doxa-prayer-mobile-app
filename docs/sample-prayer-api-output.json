        "content": [
          {
            "type": "heading",
            "attrs": {
              "level": 2
            },
            "content": [
              {
                "text": "Holy Spirit",
                "type": "text"
              }
            ]
          },
          {
            "type": "verse",
            "attrs": {
              "reference": "Acts 1:8",
              "translation": "NKJV"
            },
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "8 ",
                    "type": "text",
                    "marks": [
                      {
                        "type": "superscript"
                      }
                    ]
                  },
                  {
                    "text": "But you shall receive power  when the Holy Spirit has come upon you; and  you shall be witnesses to Me in Jerusalem, and in all Judea and  Samaria, and to the  end of the earth.”",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "text": "Stand in faith for believers to be clothed with power from the Holy Spirit, bearing bold and faithful witness among unengaged peoples as Christ’s mission advances to the nations.",
                "type": "text"
              }
            ]
          }
        ]
      },
      "content_date": "2026-03-01",
      "content_type": "static",
      "people_group_data": null
    },
