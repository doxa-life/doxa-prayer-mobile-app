        "content": [
          {
            "type": "verse",
            "attrs": {
              "reference": "Genesis 12:3",
              "translation": "NKJV"
            },
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "text": "3 ",
                    "type": "text",
                    "marks": [
                      {
                        "type": "superscript"
                      }
                    ]
                  },
                  {
                    "text": " I will bless those who bless you, And I will curse him who curses you; And in you all the families of the earth shall be blessed.”",
                    "type": "text"
                  }
                ]
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "text": "Father, today we pray that this people group would experience the promise you made to Abraham that they would be blessed through him. Amen.",
                "type": "text"
              }
            ]
          }
        ]
