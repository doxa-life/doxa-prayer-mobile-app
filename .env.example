ANON_SIGNUP_SECRET=your_secret_token_here

# Optional API base URL override. Overrides everything when set, regardless of
# build flavor. Without it, the host is chosen by the build flavor:
#   --flavor staging     -> https://campaigns-server-k4ax-production.up.railway.app
#   --flavor production   -> https://pray.doxa.life
#   unflavored debug      -> http://localhost:3000
# Set this to point any build at the local dev server or a LAN IP, e.g.:
#   API_BASE_URL=http://localhost:3000   (Android emulator: http://10.0.2.2:3000)
