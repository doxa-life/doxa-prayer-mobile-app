<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Universal Links: "Pray on the app" smart links open the installed app.
	     Requires /.well-known/apple-app-site-association on the host to verify. -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:pray.doxa.life</string>
	</array>
</dict>
</plist>
