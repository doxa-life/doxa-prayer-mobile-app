source "https://rubygems.org"

gem "fastlane"
# CocoaPods must be in the bundle: `bundle exec fastlane` exports BUNDLE_GEMFILE /
# RUBYOPT into the `flutter build ipa` subprocess, which in turn invokes `pod`.
# Without cocoapods here, bundler restricts that `pod` to this Gemfile's gems and
# it fails with "CocoaPods is installed but broken."
gem "cocoapods", "~> 1.16"
