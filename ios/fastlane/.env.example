# Copy to ios/fastlane/.env and fill in real values. The real .env is gitignored.
# fastlane loads this automatically when run from the ios/ directory.
#
# Everything here is the "Apple account" — set these once when you have the
# final org account and the whole iOS pipeline points at it. Until then you can
# run `fastlane build_unsigned` (compiles, no account needed) with none of this.

# --- Apple team / login ---------------------------------------------------
APPLE_ID=you@example.com          # Apple ID with access to the team (optional if using only the API key)
APPLE_TEAM_ID=ABCDE12345          # Developer Portal Team ID (App Store Connect -> Membership)

# --- App Store Connect API key (replaces Apple ID + 2FA for uploads) -------
# App Store Connect -> Users and Access -> Integrations -> App Store Connect API.
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_KEY_PATH=/home/youruser/asc/AuthKey_XXXXXXXXXX.p8   # keep the .p8 OUTSIDE the repo

# --- fastlane match (signing certs + profiles in a private git repo) --------
MATCH_GIT_URL=git@github.com:doxa-life/ios-certificates.git
MATCH_PASSWORD=replace_me          # encryption passphrase for the match repo

# --- OneSignal Notification Service Extension bundle ids --------------------
# These are the extension target's *Apple bundle identifiers* — NOT the
# OneSignal SDK app UUIDs (those live in the repo-root .env and are unrelated).
# Verify against `grep PRODUCT_BUNDLE_IDENTIFIER ios/Runner.xcodeproj/project.pbxproj`
# for the OneSignalNotificationServiceExtension target.
ONESIGNAL_APP_ID=life.doxa.pray.OneSignalNotificationServiceExtension
ONESIGNAL_APP_ID_STAGING=life.doxa.pray.staging.OneSignalNotificationServiceExtension

# --- Per-target campaigns-server version gate (same as Android) -------------
# PUT /api/admin/app-version/config — each token needs the content.edit permission.
STAGING_SERVER_URL=https://campaigns-server-k4ax-production.up.railway.app
STAGING_ADMIN_TOKEN=replace_me

PRODUCTION_SERVER_URL=https://pray.doxa.life
PRODUCTION_ADMIN_TOKEN=replace_me
