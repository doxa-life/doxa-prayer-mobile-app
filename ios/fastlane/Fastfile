require "tempfile"
require "json"
require "shellwords"
require "fileutils"

# ---------------------------------------------------------------------------
# Doxa Prayer — iOS build & release automation.
#
# Mirrors android/fastlane/Fastfile: two flavors map to two App Store Connect
# apps and the same per-target server version gate. Version bumping is NOT here
# — `./release.sh bump` (Android lane) edits the shared pubspec.yaml and iOS
# reads it via FLUTTER_BUILD_NAME/NUMBER.
#
# REQUIRES macOS + Xcode. Everything that ties this to a specific Apple account
# (team id, App Store Connect API key, match repo) comes from fastlane/.env, so
# the same Fastfile works against a throwaway personal team today and the final
# org account later with no edits. See SETUP.md for the account-bound steps.
# ---------------------------------------------------------------------------

FASTLANE_DIR = File.expand_path(__dir__)
ROOT = File.expand_path("../..", FASTLANE_DIR)
PUBSPEC = File.join(ROOT, "pubspec.yaml")

FLAVORS = {
  "staging" => {
    bundle: "life.doxa.pray.staging",
    scheme: "staging",
    configuration: "Release-staging",
    server_url: ENV["STAGING_SERVER_URL"],
    token: ENV["STAGING_ADMIN_TOKEN"],
  },
  "production" => {
    bundle: "life.doxa.pray",
    scheme: "production",
    configuration: "Release-production",
    server_url: ENV["PRODUCTION_SERVER_URL"],
    token: ENV["PRODUCTION_ADMIN_TOKEN"],
  },
}

default_platform(:ios)

platform :ios do
  # ---- helpers ------------------------------------------------------------

  def require_flavor(flavor)
    UI.user_error!("Unknown flavor #{flavor.inspect} (use staging or production)") unless FLAVORS.key?(flavor)
    FLAVORS[flavor]
  end

  # Read `version: X.Y.Z+N` from pubspec.yaml (shared with Android).
  def read_semver
    line = File.read(PUBSPEC)[/^version:\s*(.+)$/, 1]
    UI.user_error!("Could not find `version:` in #{PUBSPEC}") unless line
    m = line.strip.match(/^(\d+\.\d+\.\d+)\+\d+$/)
    UI.user_error!("Unexpected version format: #{line.strip} (want X.Y.Z+N)") unless m
    m[1]
  end

  # Build the App Store Connect API key token used by gym/pilot in place of an
  # Apple ID + 2FA. Returns nil if not configured (so account-free lanes still run).
  def asc_api_key
    return nil if ENV["ASC_KEY_ID"].to_s.empty?
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      in_house: false,
    )
  end

  # ---- lanes --------------------------------------------------------------

  desc "Compile the iOS app WITHOUT signing — validates the build with no Apple account. flavor: staging|production"
  lane :build_unsigned do |options|
    flavor = (options[:flavor] || "staging").to_s
    require_flavor(flavor)
    sh("cd #{ROOT.shellescape} && flutter build ios --no-codesign --release --flavor #{flavor.shellescape}")
    UI.success("Compiled #{flavor} (unsigned). The iOS build pipeline works; signing/upload need an Apple account.")
  end

  desc "Build a signed App Store IPA for a flavor. flavor: staging|production"
  lane :build_ipa do |options|
    flavor = (options[:flavor] || "staging").to_s
    cfg = require_flavor(flavor)

    setup_ci if ENV["CI"]
    api_key = asc_api_key

    # Install the App Store cert + profile for this bundle id from the match repo.
    match(
      type: "appstore",
      app_identifier: cfg[:bundle],
      readonly: true,
      api_key: api_key,
    )

    team_id = ENV["APPLE_TEAM_ID"]
    UI.user_error!("APPLE_TEAM_ID is not set (see fastlane/.env.example)") if team_id.to_s.empty?

    # Generate the export options plist from env so the team id stays a single
    # variable. The profile name is match's deterministic default.
    export_plist = Tempfile.new(["ExportOptions-#{flavor}", ".plist"])
    export_plist.write(<<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>method</key><string>app-store</string>
        <key>teamID</key><string>#{team_id}</string>
        <key>signingStyle</key><string>manual</string>
        <key>provisioningProfiles</key>
        <dict>
          <key>#{cfg[:bundle]}</key><string>match AppStore #{cfg[:bundle]}</string>
        </dict>
      </dict>
      </plist>
    PLIST
    export_plist.close

    sh("cd #{ROOT.shellescape} && flutter build ipa --release " \
       "--flavor #{flavor.shellescape} " \
       "--export-options-plist=#{export_plist.path.shellescape}")

    ipa = Dir[File.join(ROOT, "build", "ios", "ipa", "*.ipa")].max_by { |f| File.mtime(f) }
    UI.user_error!("No IPA produced in build/ios/ipa") unless ipa
    UI.success("Built #{ipa}")
    ipa
  end

  desc "Build + upload to TestFlight and update the server gate. flavor: staging|production"
  lane :deploy do |options|
    flavor = (options[:flavor] || "").to_s
    cfg = require_flavor(flavor)

    api_key = asc_api_key
    UI.user_error!("ASC_KEY_ID is not set — TestFlight upload needs the App Store Connect API key (see fastlane/.env.example)") if api_key.nil?

    ipa = build_ipa(flavor: flavor)

    upload_to_testflight(
      app_identifier: cfg[:bundle],
      ipa: ipa,
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )

    update_server_version(flavor: flavor)
    UI.success("Deployed #{read_semver} (#{flavor}) to TestFlight + updated #{flavor} gate")
  end

  desc "Update the campaigns-server version gate for a flavor. flavor: staging|production"
  lane :update_server_version do |options|
    flavor = (options[:flavor] || "").to_s
    cfg = require_flavor(flavor)
    UI.user_error!("Missing server URL/token for #{flavor} (see fastlane/.env.example)") if cfg[:server_url].to_s.empty? || cfg[:token].to_s.empty?

    semver = read_semver
    body = JSON.generate(latest_version: semver)
    url = "#{cfg[:server_url]}/api/admin/app-version/config"
    sh(%(curl -fsS -X PUT #{url.shellescape} ) +
       %(-H "Authorization: Bearer #{cfg[:token]}" ) +
       %(-H "Content-Type: application/json" ) +
       %(-d #{body.shellescape}))
    UI.success("Set #{flavor} latest_version = #{semver}")
  end

  # ---- store screenshots --------------------------------------------------

  desc "Capture + frame App Store screenshots on the simulator (6.9\" iPhone + 13\" iPad, staging data), then stage them. macOS ONLY. Upload with `upload_screenshots`."
  lane :screenshots do
    sh("cd #{ROOT.shellescape} && tool/screenshots/capture_ios.sh")
    count = stage_screenshots
    UI.success("Staged #{count} screenshot(s) under fastlane/screenshots/en-US. Review, then: bundle exec fastlane upload_screenshots")
  end

  desc "Upload the framed App Store screenshots to a flavor's listing (default production). Assumes `screenshots` (or tool/screenshots/capture_ios.sh) has run."
  lane :upload_screenshots do |options|
    flavor = (options[:flavor] || "production").to_s
    cfg = require_flavor(flavor)

    api_key = asc_api_key
    UI.user_error!("ASC_KEY_ID is not set — screenshot upload needs the App Store Connect API key (see fastlane/.env.example)") if api_key.nil?

    count = stage_screenshots
    UI.user_error!("No framed screenshots found — run `fastlane screenshots` first") if count.zero?

    upload_to_app_store(
      app_identifier: cfg[:bundle],
      api_key: api_key,
      screenshots_path: File.join(FASTLANE_DIR, "screenshots"),
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
    )
    UI.success("Uploaded #{count} screenshot(s) to the #{flavor} App Store listing")
  end
end

# ---- non-lane helpers ------------------------------------------------------

# Copy the framed screenshots produced by tool/screenshots/capture_ios.sh
# (build/screenshots_framed/ios/<key>/) into fastlane/screenshots/en-US/, which
# is where deliver (upload_to_app_store) reads them. deliver infers the display
# family from each image's dimensions, so the files are prefixed by device key
# to keep the two families' identically-named shots distinct. Returns the count.
def stage_screenshots
  src_root = File.join(ROOT, "build", "screenshots_framed", "ios")
  dst = File.join(FASTLANE_DIR, "screenshots", "en-US")
  FileUtils.rm_rf(File.join(FASTLANE_DIR, "screenshots"))
  FileUtils.mkdir_p(dst)
  staged = 0
  Dir[File.join(src_root, "*")].sort.each do |dir|
    next unless File.directory?(dir)
    key = File.basename(dir)
    Dir[File.join(dir, "*.png")].sort.each do |png|
      FileUtils.cp(png, File.join(dst, "#{key}_#{File.basename(png)}"))
      staged += 1
    end
  end
  UI.message("Staged #{staged} screenshot(s) into fastlane/screenshots/en-US")
  staged
end
